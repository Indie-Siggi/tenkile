        {
          "id": "samsung-dts-passthrough",
          "title": "No DTS Audio Passthrough",
          "description": "Samsung Tizen TVs do not support DTS or DTS-HD audio passthrough. Audio will be decoded and sent as PCM or transcoded to AC3.",
          "severity": "warning",
          "codecs": ["dts", "dtshd"],
          "workaround": "Enable audio transcoding to AC3/EAC3 in Jellyfin server settings",
          "resolved": false
        },
        {
          "id": "samsung-mkv-h264-hdr",
          "title": "MKV Container with H.264 HDR Issues",
          "description": "Some Samsung models have issues playing H.264 HDR content in MKV containers. HEVC in MP4 usually works better.",
          "severity": "info",
          "codecs": ["h264"],
          "containers": ["mkv"],
          "workaround": "Use HEVC codec or MP4 container for HDR content",
          "resolved": false
        }
      ],
      "source": "official",
      "votes_up": 245,
      "votes_down": 12,
      "verified": true,
      "notes": "Flagship Neo QLED 4K TV. Excellent HEVC decoding. No Dolby Vision support."
    },
